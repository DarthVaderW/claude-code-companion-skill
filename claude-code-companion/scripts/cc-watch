#!/usr/bin/env bash
set -u

QUIET_AFTER_DEFAULT=60
EFFORT_DEFAULT=max
ALLOWED_READONLY_TOOLS="Read,Grep,Glob,LS"

usage() {
  cat <<'EOF'
Usage:
  cc-watch run [options] -- PROMPT
  cc-watch start [options] -- PROMPT
  cc-watch status <job-id> [--cwd DIR]
  cc-watch result <job-id> [--cwd DIR]
  cc-watch cancel <job-id> [--cwd DIR]
  cc-watch doctor [options]

Options:
  --cwd DIR             Target working directory. Default: current directory.
  --effort LEVEL        Claude effort level. Default: max.
  --model MODEL         Optional Claude model.
  --claude PATH         Claude binary. Default: $CLAUDE_BIN or claude.
  --quiet-after SEC     Seconds without stream events before running-quiet.
  --allow-bash          Add Bash to the read-only tool allowlist. Off by default.
  --allow-mcp           Load Claude Code MCP config instead of strict empty MCP.
  --read-write          Allow Claude Code's default write-capable tools.
  --persist-session     Allow Claude Code to persist this print-mode session.
  --resume SESSION_ID   Resume a persisted Claude Code session.
  --continue            Continue Claude Code's most recent session for cwd.
  --                    End options; remaining text is the prompt.

The script consumes Claude's raw stream-json output and prints only compact
status plus the final result. Async state is stored under <cwd>/.cc-watch/.
EOF
}

die() {
  printf 'cc-watch: %s\n' "$*" >&2
  exit 1
}

now_epoch() {
  date +%s
}

absolute_dir() {
  local dir="$1"
  (cd "$dir" 2>/dev/null && pwd) || return 1
}

script_path() {
  local src="${BASH_SOURCE[0]}"
  local dir
  dir="$(cd "$(dirname "$src")" 2>/dev/null && pwd)" || return 1
  printf '%s/%s\n' "$dir" "$(basename "$src")"
}

state_root_for() {
  local cwd="$1"
  printf '%s/.cc-watch\n' "$cwd"
}

ensure_state_root() {
  local root="$1"
  mkdir -p "$root" || die "cannot create state root: $root"
  if [ ! -f "$root/.gitignore" ]; then
    printf '*\n!.gitignore\n' > "$root/.gitignore"
  fi
}

job_dir_for() {
  local cwd="$1"
  local job_id="$2"
  printf '%s/%s\n' "$(state_root_for "$cwd")" "$job_id"
}

new_job_id() {
  printf 'cc-%s-%s\n' "$(date +%Y%m%d%H%M%S)" "$$"
}

write_file() {
  local path="$1"
  shift
  printf '%s\n' "$*" > "$path"
}

read_file() {
  local path="$1"
  if [ -f "$path" ]; then
    cat "$path"
  fi
}

is_pid_alive() {
  local pid="$1"
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

resolve_claude_binary() {
  if [ -z "$CLAUDE" ]; then
    return 1
  fi

  if printf '%s' "$CLAUDE" | grep -q '/'; then
    [ -x "$CLAUDE" ] || return 1
    printf '%s\n' "$CLAUDE"
    return 0
  fi

  local resolved
  resolved="$(command -v "$CLAUDE" 2>/dev/null || true)"
  if [ -n "$resolved" ]; then
    printf '%s\n' "$resolved"
    return 0
  fi

  if [ "$CLAUDE" = "claude" ] && [ -x "$HOME/.local/bin/claude" ]; then
    printf '%s\n' "$HOME/.local/bin/claude"
    return 0
  fi

  return 1
}

preflight_claude() {
  local stderr_log="$1"
  local resolved
  resolved="$(resolve_claude_binary)" || {
    printf 'Claude binary not found or not executable: %s\n' "$CLAUDE" >> "$stderr_log"
    return 127
  }

  CLAUDE="$resolved"
  write_file "$JOB_DIR/claude" "$CLAUDE"
  "$CLAUDE" --version > "$JOB_DIR/claude_version" 2>> "$stderr_log" || {
    local code="$?"
    printf 'Claude version check failed for: %s\n' "$CLAUDE" >> "$stderr_log"
    return "$code"
  }
}

json_field_from_stdin() {
  local field="$1"
  perl -MJSON::PP -CS -e '
    my $field = shift;
    my $line = do { local $/; <STDIN> };
    my $json = eval { JSON::PP->new->decode($line) };
    exit 2 unless $json && exists $json->{$field} && defined $json->{$field};
    print $json->{$field};
  ' "$field"
}

extract_result_line() {
  local line="$1"
  local result session
  result="$(printf '%s' "$line" | json_field_from_stdin result 2>/dev/null || true)"
  session="$(printf '%s' "$line" | json_field_from_stdin session_id 2>/dev/null || true)"
  printf '%s' "$result"
  if [ -n "$session" ]; then
    printf '%s\n' "$session" > "$JOB_DIR/session_id"
  fi
}

parse_prompt() {
  if [ "$#" -gt 0 ]; then
    printf '%s\n' "$*"
  else
    cat
  fi
}

parse_run_options() {
  CWD="."
  EFFORT="$EFFORT_DEFAULT"
  MODEL=""
  CLAUDE="${CLAUDE_BIN:-claude}"
  QUIET_AFTER="$QUIET_AFTER_DEFAULT"
  ALLOW_BASH=0
  ALLOW_MCP=0
  READ_WRITE=0
  NO_SESSION_PERSISTENCE=1
  RESUME_SESSION=""
  CONTINUE_SESSION=0
  PROMPT_ARGS=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --cwd)
        [ "$#" -ge 2 ] || die "--cwd requires a value"
        CWD="$2"
        shift 2
        ;;
      --effort)
        [ "$#" -ge 2 ] || die "--effort requires a value"
        EFFORT="$2"
        shift 2
        ;;
      --model)
        [ "$#" -ge 2 ] || die "--model requires a value"
        MODEL="$2"
        shift 2
        ;;
      --claude)
        [ "$#" -ge 2 ] || die "--claude requires a value"
        CLAUDE="$2"
        shift 2
        ;;
      --quiet-after)
        [ "$#" -ge 2 ] || die "--quiet-after requires a value"
        QUIET_AFTER="$2"
        shift 2
        ;;
      --allow-bash)
        ALLOW_BASH=1
        shift
        ;;
      --allow-mcp)
        ALLOW_MCP=1
        shift
        ;;
      --read-write)
        READ_WRITE=1
        shift
        ;;
      --persist-session)
        NO_SESSION_PERSISTENCE=0
        shift
        ;;
      --resume)
        [ "$#" -ge 2 ] || die "--resume requires a session id"
        RESUME_SESSION="$2"
        NO_SESSION_PERSISTENCE=0
        shift 2
        ;;
      --continue)
        CONTINUE_SESSION=1
        NO_SESSION_PERSISTENCE=0
        shift
        ;;
      --)
        shift
        PROMPT_ARGS=("$@")
        break
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown option: $1"
        ;;
    esac
  done

  if [ -n "$RESUME_SESSION" ] && [ "$CONTINUE_SESSION" = "1" ]; then
    die "--resume and --continue cannot be used together"
  fi

  CWD="$(absolute_dir "$CWD")" || die "cannot enter cwd: $CWD"
}

parse_job_options() {
  CWD="."
  JOB_ID=""

  [ "$#" -ge 1 ] || die "missing job id"
  JOB_ID="$1"
  shift

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --cwd)
        [ "$#" -ge 2 ] || die "--cwd requires a value"
        CWD="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown option: $1"
        ;;
    esac
  done

  CWD="$(absolute_dir "$CWD")" || die "cannot enter cwd: $CWD"
  JOB_DIR="$(job_dir_for "$CWD" "$JOB_ID")"
}

parse_doctor_options() {
  CWD="."
  CLAUDE="${CLAUDE_BIN:-claude}"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --cwd)
        [ "$#" -ge 2 ] || die "--cwd requires a value"
        CWD="$2"
        shift 2
        ;;
      --claude)
        [ "$#" -ge 2 ] || die "--claude requires a value"
        CLAUDE="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown option: $1"
        ;;
    esac
  done

  CWD="$(absolute_dir "$CWD")" || die "cannot enter cwd: $CWD"
}

write_config() {
  ensure_state_root "$(state_root_for "$CWD")"
  mkdir -p "$JOB_DIR" || die "cannot create job dir: $JOB_DIR"
  write_file "$JOB_DIR/job_id" "$JOB_ID"
  write_file "$JOB_DIR/cwd" "$CWD"
  write_file "$JOB_DIR/claude" "$CLAUDE"
  write_file "$JOB_DIR/effort" "$EFFORT"
  write_file "$JOB_DIR/model" "$MODEL"
  write_file "$JOB_DIR/quiet_after" "$QUIET_AFTER"
  if [ "$READ_WRITE" = "1" ]; then
    write_file "$JOB_DIR/readonly" "0"
  else
    write_file "$JOB_DIR/readonly" "1"
  fi
  write_file "$JOB_DIR/allow_bash" "$ALLOW_BASH"
  write_file "$JOB_DIR/allow_mcp" "$ALLOW_MCP"
  write_file "$JOB_DIR/read_write" "$READ_WRITE"
  write_file "$JOB_DIR/no_session_persistence" "$NO_SESSION_PERSISTENCE"
  write_file "$JOB_DIR/resume_session" "$RESUME_SESSION"
  write_file "$JOB_DIR/continue_session" "$CONTINUE_SESSION"
  write_file "$JOB_DIR/status" "starting"
  write_file "$JOB_DIR/started_at" "$(now_epoch)"
  write_file "$JOB_DIR/last_event_at" "0"
  parse_prompt "${PROMPT_ARGS[@]}" > "$JOB_DIR/prompt.md"
}

load_config() {
  CWD="$(read_file "$JOB_DIR/cwd")"
  CLAUDE="$(read_file "$JOB_DIR/claude")"
  EFFORT="$(read_file "$JOB_DIR/effort")"
  MODEL="$(read_file "$JOB_DIR/model")"
  QUIET_AFTER="$(read_file "$JOB_DIR/quiet_after")"
  ALLOW_BASH="$(read_file "$JOB_DIR/allow_bash")"
  ALLOW_MCP="$(read_file "$JOB_DIR/allow_mcp")"
  READ_WRITE="$(read_file "$JOB_DIR/read_write")"
  [ -n "$ALLOW_BASH" ] || ALLOW_BASH=0
  [ -n "$ALLOW_MCP" ] || ALLOW_MCP=0
  [ -n "$READ_WRITE" ] || READ_WRITE=0
  NO_SESSION_PERSISTENCE="$(read_file "$JOB_DIR/no_session_persistence")"
  RESUME_SESSION="$(read_file "$JOB_DIR/resume_session")"
  CONTINUE_SESSION="$(read_file "$JOB_DIR/continue_session")"
}

build_claude_args() {
  CLAUDE_ARGS=(-p --output-format stream-json --verbose --effort "$EFFORT" --permission-mode dontAsk)
  if [ -n "$MODEL" ]; then
    CLAUDE_ARGS+=(--model "$MODEL")
  fi
  if [ -n "$RESUME_SESSION" ]; then
    CLAUDE_ARGS+=(--resume "$RESUME_SESSION")
  elif [ "$CONTINUE_SESSION" = "1" ]; then
    CLAUDE_ARGS+=(--continue)
  elif [ "$NO_SESSION_PERSISTENCE" = "1" ]; then
    CLAUDE_ARGS+=(--no-session-persistence)
  fi
  if [ "$READ_WRITE" != "1" ]; then
    local allowed_tools="$ALLOWED_READONLY_TOOLS"
    if [ "$ALLOW_BASH" = "1" ]; then
      allowed_tools="$allowed_tools,Bash"
    fi
    CLAUDE_ARGS+=(--tools "$allowed_tools")
  fi
  if [ "$ALLOW_MCP" != "1" ]; then
    CLAUDE_ARGS+=(--strict-mcp-config --mcp-config '{"mcpServers":{}}')
  fi
}

update_running_status() {
  local last_event="$1"
  local now delta status
  now="$(now_epoch)"
  delta=$((now - last_event))
  if [ "$last_event" -gt 0 ] && [ "$delta" -le "$QUIET_AFTER" ]; then
    status="running-active"
  else
    status="running-quiet"
  fi
  write_file "$JOB_DIR/status" "$status"
}

worker() {
  JOB_DIR="$1"
  [ -d "$JOB_DIR" ] || die "missing job dir: $JOB_DIR"
  load_config

  local fifo="$JOB_DIR/stdout.fifo"
  local stderr_log="$JOB_DIR/stderr.log"
  local stdout_log="$JOB_DIR/stdout.jsonl"
  local exit_code_file="$JOB_DIR/exit_code"
  local result_file="$JOB_DIR/result.txt"
  local final_line_file="$JOB_DIR/final-result.json"

  rm -f "$fifo"
  mkfifo "$fifo" || die "cannot create fifo"
  : > "$stderr_log"
  : > "$stdout_log"
  : > "$result_file"
  rm -f "$exit_code_file" "$final_line_file"

  preflight_claude "$stderr_log" || {
    local code="$?"
    write_file "$JOB_DIR/exit_code" "$code"
    write_file "$JOB_DIR/status" "failed"
    return "$code"
  }

  build_claude_args
  write_file "$JOB_DIR/status" "running-quiet"

  (
    cd "$CWD" || exit 97
    "$CLAUDE" "${CLAUDE_ARGS[@]}" < "$JOB_DIR/prompt.md" > "$fifo" 2> "$stderr_log"
    printf '%s\n' "$?" > "$exit_code_file"
  ) &
  local claude_pid="$!"
  write_file "$JOB_DIR/claude_pid" "$claude_pid"

  local line ts saw_result=0
  local result_is_error=0 result_subtype=""
  while IFS= read -r line || [ -n "$line" ]; do
    ts="$(now_epoch)"
    write_file "$JOB_DIR/last_event_at" "$ts"
    update_running_status "$ts"
    printf '%s\n' "$line" >> "$stdout_log"
    if printf '%s\n' "$line" | grep -q '"type"[[:space:]]*:[[:space:]]*"result"'; then
      saw_result=1
      printf '%s\n' "$line" > "$final_line_file"
      extract_result_line "$line" > "$result_file"
      result_is_error="$(printf '%s' "$line" | json_field_from_stdin is_error 2>/dev/null || true)"
      result_subtype="$(printf '%s' "$line" | json_field_from_stdin subtype 2>/dev/null || true)"
    fi
  done < "$fifo"

  wait "$claude_pid"
  local wait_code="$?"
  local exit_code="$wait_code"
  if [ -f "$exit_code_file" ]; then
    exit_code="$(cat "$exit_code_file")"
  fi
  write_file "$JOB_DIR/exit_code" "$exit_code"
  rm -f "$fifo"

  if [ "$exit_code" = "0" ] && [ "$saw_result" = "1" ]; then
    if [ "$result_is_error" = "1" ] || printf '%s' "$result_subtype" | grep -q '^error'; then
      write_file "$JOB_DIR/status" "failed"
      printf 'Claude final result was an error event: subtype=%s is_error=%s\n' \
        "$result_subtype" "$result_is_error" >> "$stderr_log"
      return 1
    fi
    write_file "$JOB_DIR/status" "finished"
    return 0
  fi

  if [ "$exit_code" = "0" ]; then
    write_file "$JOB_DIR/status" "failed"
    printf 'Claude exited with code 0 but no final result event was found.\n' >> "$stderr_log"
  else
    write_file "$JOB_DIR/status" "failed"
  fi
  return 1
}

render_status() {
  [ -d "$JOB_DIR" ] || {
    printf 'unknown job=%s reason=missing-state\n' "$JOB_ID"
    return 3
  }

  local status worker_pid claude_pid last_event quiet_after now delta rendered exit_code session
  local no_session_persistence session_resumable
  status="$(read_file "$JOB_DIR/status")"
  worker_pid="$(read_file "$JOB_DIR/worker_pid")"
  claude_pid="$(read_file "$JOB_DIR/claude_pid")"
  last_event="$(read_file "$JOB_DIR/last_event_at")"
  quiet_after="$(read_file "$JOB_DIR/quiet_after")"
  exit_code="$(read_file "$JOB_DIR/exit_code")"
  session="$(read_file "$JOB_DIR/session_id")"
  no_session_persistence="$(read_file "$JOB_DIR/no_session_persistence")"

  [ -n "$last_event" ] || last_event=0
  [ -n "$quiet_after" ] || quiet_after="$QUIET_AFTER_DEFAULT"

  if [ "$status" = "finished" ] || [ "$status" = "failed" ] || [ "$status" = "canceled" ]; then
    rendered="$status"
  elif is_pid_alive "$claude_pid" || is_pid_alive "$worker_pid"; then
    now="$(now_epoch)"
    delta=$((now - last_event))
    if [ "$last_event" -gt 0 ] && [ "$delta" -le "$quiet_after" ]; then
      rendered="running-active"
    else
      rendered="running-quiet"
    fi
  else
    rendered="failed"
  fi

  printf '%s job=%s' "$rendered" "$JOB_ID"
  [ -n "$claude_pid" ] && printf ' claude_pid=%s' "$claude_pid"
  [ -n "$worker_pid" ] && printf ' worker_pid=%s' "$worker_pid"
  [ -n "$last_event" ] && [ "$last_event" != "0" ] && printf ' last_event_at=%s' "$last_event"
  [ -n "$exit_code" ] && printf ' exit_code=%s' "$exit_code"
  if [ -n "$session" ]; then
    session_resumable=yes
    [ "$no_session_persistence" = "1" ] && session_resumable=no
    printf ' session_id=%s session_resumable=%s' "$session" "$session_resumable"
  fi
  printf '\n'

  case "$rendered" in
    finished) return 0 ;;
    running-active|running-quiet) return 2 ;;
    *) return 1 ;;
  esac
}

cmd_run() {
  parse_run_options "$@"
  JOB_ID="$(new_job_id)"
  JOB_DIR="$(job_dir_for "$CWD" "$JOB_ID")"
  write_config
  write_file "$JOB_DIR/worker_pid" "$$"

  printf '[cc] job=%s status=starting\n' "$JOB_ID"
  worker "$JOB_DIR"
  local code="$?"
  render_status >/dev/null || true

  if [ "$code" -eq 0 ]; then
    local session no_session_persistence session_resumable
    session="$(read_file "$JOB_DIR/session_id")"
    no_session_persistence="$(read_file "$JOB_DIR/no_session_persistence")"
    printf '[cc] job=%s status=finished' "$JOB_ID"
    if [ -n "$session" ]; then
      session_resumable=yes
      [ "$no_session_persistence" = "1" ] && session_resumable=no
      printf ' session_id=%s session_resumable=%s' "$session" "$session_resumable"
    fi
    printf '\n'
    cat "$JOB_DIR/result.txt"
    printf '\n'
  else
    printf '[cc] job=%s status=failed\n' "$JOB_ID" >&2
    tail -40 "$JOB_DIR/stderr.log" >&2 2>/dev/null || true
  fi
  return "$code"
}

cmd_start() {
  parse_run_options "$@"
  JOB_ID="$(new_job_id)"
  JOB_DIR="$(job_dir_for "$CWD" "$JOB_ID")"
  write_config

  local self
  self="$(script_path)" || die "cannot resolve script path"
  "$self" __worker "$JOB_DIR" > "$JOB_DIR/monitor.log" 2>&1 &
  local worker_pid="$!"
  write_file "$JOB_DIR/worker_pid" "$worker_pid"
  printf '%s\n' "$JOB_ID"
}

cmd_result() {
  parse_job_options "$@"
  [ -d "$JOB_DIR" ] || die "unknown job: $JOB_ID"

  local status
  status="$(read_file "$JOB_DIR/status")"
  if [ "$status" = "finished" ] && [ -f "$JOB_DIR/result.txt" ]; then
    cat "$JOB_DIR/result.txt"
    printf '\n'
    return 0
  fi

  render_status
  return $?
}

cmd_cancel() {
  parse_job_options "$@"
  [ -d "$JOB_DIR" ] || die "unknown job: $JOB_ID"

  local claude_pid worker_pid
  claude_pid="$(read_file "$JOB_DIR/claude_pid")"
  worker_pid="$(read_file "$JOB_DIR/worker_pid")"

  if is_pid_alive "$claude_pid"; then
    kill "$claude_pid" 2>/dev/null || true
  fi
  if is_pid_alive "$worker_pid"; then
    kill "$worker_pid" 2>/dev/null || true
  fi
  write_file "$JOB_DIR/status" "canceled"
  printf 'canceled job=%s\n' "$JOB_ID"
}

render_env_status() {
  local key="$1"
  if [ -n "${!key:-}" ]; then
    printf '%s=REDACTED\n' "$key"
  else
    printf '%s=unset\n' "$key"
  fi
}

render_flag_status() {
  local help_text="$1"
  local label="$2"
  local pattern="$3"
  if printf '%s' "$help_text" | grep -q -- "$pattern"; then
    printf 'flag_%s=yes\n' "$label"
  else
    printf 'flag_%s=no\n' "$label"
  fi
}

render_state_ignore_status() {
  local root
  root="$(state_root_for "$CWD")"
  printf 'state_root=%s\n' "$root"
  if git -C "$CWD" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    if git -C "$CWD" check-ignore -q .cc-watch/; then
      printf 'state_git_ignored=yes\n'
    else
      printf 'state_git_ignored=no\n'
    fi
  else
    printf 'state_git_ignored=not-git\n'
  fi
}

cmd_doctor() {
  parse_doctor_options "$@"

  local resolved version help_text
  printf 'cwd=%s\n' "$CWD"
  if resolved="$(resolve_claude_binary)"; then
    CLAUDE="$resolved"
    printf 'claude_path=%s\n' "$CLAUDE"
    version="$("$CLAUDE" --version 2>/dev/null || true)"
    if [ -n "$version" ]; then
      printf 'claude_version=%s\n' "$version"
    else
      printf 'claude_version=unknown\n'
    fi
    help_text="$("$CLAUDE" --help 2>/dev/null || true)"
    render_flag_status "$help_text" "print" "-p, --print"
    render_flag_status "$help_text" "stream_json" "stream-json"
    render_flag_status "$help_text" "tools" "--tools"
    render_flag_status "$help_text" "strict_mcp_config" "--strict-mcp-config"
    render_flag_status "$help_text" "no_session_persistence" "--no-session-persistence"
    render_flag_status "$help_text" "permission_mode" "--permission-mode"
  else
    printf 'claude_path=missing\n'
    printf 'claude_version=unknown\n'
  fi

  render_env_status ANTHROPIC_API_KEY
  render_env_status ANTHROPIC_AUTH_TOKEN
  render_env_status CLAUDE_CODE_OAUTH_TOKEN
  render_env_status ANTHROPIC_BASE_URL
  render_env_status HTTP_PROXY
  render_env_status HTTPS_PROXY
  render_env_status ALL_PROXY
  render_env_status NO_PROXY
  render_state_ignore_status
}

main() {
  [ "$#" -gt 0 ] || {
    usage
    exit 2
  }

  local command="$1"
  shift

  case "$command" in
    run) cmd_run "$@" ;;
    start) cmd_start "$@" ;;
    status)
      parse_job_options "$@"
      render_status
      ;;
    result) cmd_result "$@" ;;
    cancel) cmd_cancel "$@" ;;
    doctor) cmd_doctor "$@" ;;
    __worker) worker "$@" ;;
    -h|--help) usage ;;
    *) die "unknown command: $command" ;;
  esac
}

main "$@"
